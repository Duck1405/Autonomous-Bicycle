      <link name="center_line_link">
        <visual name="dash_00"><pose>-40 0 0.04 0 0 0</pose><geometry><box><size>3 0.12 0.012</size></box></geometry><material><ambient>1 0.85 0.05 1</ambient><diffuse>1 0.85 0.05 1</diffuse></material></visual>
        <visual name="dash_01"><pose>-32 0 0.04 0 0 0</pose><geometry><box><size>3 0.12 0.012</size></box></geometry><material><ambient>1 0.85 0.05 1</ambient><diffuse>1 0.85 0.05 1</diffuse></material></visual>
